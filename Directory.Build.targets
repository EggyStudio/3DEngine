<Project>

    <!-- Auto-pack only during CI: dotnet build -p:ContinuousIntegrationBuild=true -->
    <PropertyGroup Condition="'$(IsPackable)' != 'false' AND '$(ContinuousIntegrationBuild)' == 'true'">
        <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    </PropertyGroup>

    <!-- Default package description and tags (override per-project when needed) -->
    <PropertyGroup Condition="'$(IsPackable)' != 'false'">
        <Description Condition="'$(Description)' == ''">3D Game Engine | Vulkan | SDL3 | .NET 10 | C# 14</Description>
        <PackageTags Condition="'$(PackageTags)' == ''">3D;Game;Engine;.Net10;C#14</PackageTags>
    </PropertyGroup>

    <!-- UniversalSceneDescription ships its native plugin tree
         (runtimes/<rid>/native/usd/**) via a transitive .targets file that every
         project consuming USD (directly or via ProjectReference) re-imports.
         When the engine publishes (PublishSingleFile=true, SelfContained=true)
         each transitive contributor stages identical files at identical relative
         paths, tripping NETSDK1152. Demote the duplicate-publish-output check to
         a warning so the SDK picks one copy of each file. The duplicates are
         byte-identical (same nuget package, same RID), so deduplication is safe. -->
    <PropertyGroup>
        <ErrorOnDuplicatePublishOutputFiles>false</ErrorOnDuplicatePublishOutputFiles>
    </PropertyGroup>

</Project>
